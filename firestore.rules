rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Test-Modus: Alle Lese- und Schreiboperationen erlaubt bis 1. April 2026.
    // WICHTIG: Vor dem 1. April 2026 neue Regeln einrichten!
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 4, 1);
    }
  }
}
