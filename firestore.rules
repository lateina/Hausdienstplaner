rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Posts: vollständiger Lese- und Schreibzugriff
    // Da die App kein Firebase Auth nutzt, erlauben wir alles.
    // Schutz vor Fremdzugriff besteht darin, dass die Project-ID
    // nicht öffentlich bekannt ist.
    match /posts/{postId} {
      allow read, write: if true;
    }

    // FCM Tokens: Lese- und Schreibzugriff (Firebase Admin SDK umgeht diese Regeln)
    match /fcm_tokens/{userId} {
      allow read, write: if true;
    }

  }
}
